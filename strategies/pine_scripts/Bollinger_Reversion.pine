//@version=5
strategy("AlphaTrader - Bollinger Reversion", overlay=true, initial_capital=100000, default_qty_type=strategy.percent_of_equity, default_qty_value=10)

// === INPUTS ===
bbLen = input.int(20, "BB Period")
bbStd = input.float(2.0, "BB StdDev")
rsiLen = input.int(14, "RSI Period")
rsiOversold = input.int(35, "RSI Oversold")
rsiOverbought = input.int(65, "RSI Overbought")

// === INDICATORS ===
basis = ta.sma(close, bbLen)
dev = bbStd * ta.stdev(close, bbLen)
upper = basis + dev
lower = basis - dev
rsi = ta.rsi(close, rsiLen)

// === CONDITIONS ===
// Long: Price at/below lower band + RSI oversold
atLower = close <= lower or close[1] <= lower[1]
rsiOversoldCond = rsi < rsiOversold

// Short: Price at/above upper band + RSI overbought
atUpper = close >= upper or close[1] >= upper[1]
rsiOverboughtCond = rsi > rsiOverbought

// === ENTRIES ===
if atLower and rsiOversoldCond
    strategy.entry("Long", strategy.long, comment="BB Reversion Long")

if atUpper and rsiOverboughtCond
    strategy.entry("Short", strategy.short, comment="BB Reversion Short")

// === EXITS ===
// Exit at middle band (mean reversion target)
if strategy.position_size > 0 and close >= basis
    strategy.close("Long", comment="Mean Reversion Target")

if strategy.position_size < 0 and close <= basis
    strategy.close("Short", comment="Mean Reversion Target")

// === PLOTS ===
p1 = plot(upper, "Upper", color=color.new(color.red, 50))
p2 = plot(lower, "Lower", color=color.new(color.green, 50))
fill(p1, p2, title="BB Background", color=color.new(color.blue, 95))
plot(basis, "Basis", color=color.new(color.orange, 0))

// RSI panel
hline(rsiOverbought, "Overbought", color=color.red)
hline(rsiOversold, "Oversold", color=color.green)
plot(rsi, "RSI", color=color.purple, display=display.pane)

// === ALERTS ===
alertcondition(atLower and rsiOversoldCond, "BB Long", "BB Reversion Long on {{ticker}}")
alertcondition(atUpper and rsiOverboughtCond, "BB Short", "BB Reversion Short on {{ticker}}")

// === WEBHOOK ===
// {"symbol":"{{ticker}}","side":"{{strategy.order.action}}","price":{{close}},"quantity":1,"strategy":"bollinger_reversion","timeframe":"{{interval}}","passphrase":"YOUR_SECRET"}
